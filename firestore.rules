rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ─────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    function isJudge() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/judges/$(request.auth.token.email));
    }

    // ─── Participants ─────────────────────────────────────────────────────
    match /participants/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isJudge();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Submissions ──────────────────────────────────────────────────────
    match /submissions/{uid} {
      allow read: if isOwner(uid) || isAdmin() || isJudge();

      // Create: only the owner, only once (no existing doc)
      allow create: if isOwner(uid) && !exists(/databases/$(database)/documents/submissions/$(uid));

      // Update: owner can update ONLY if status is in_progress (not submitted/locked)
      // Admins can update anything
      allow update: if isAdmin() ||
        (isOwner(uid) && resource.data.status == 'in_progress');

      allow delete: if isAdmin();
    }

    // ─── Evaluations ──────────────────────────────────────────────────────
    match /evaluations/{evalId} {
      allow read: if isJudge() || isAdmin();
      allow create: if isJudge();
      allow update: if isJudge() && resource.data.judgeId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── Logs ─────────────────────────────────────────────────────────────
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // ─── Config ───────────────────────────────────────────────────────────
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Admins ───────────────────────────────────────────────────────────
    match /admins/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Judges ───────────────────────────────────────────────────────────
    match /judges/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
